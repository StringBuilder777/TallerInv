---
import Layout from "../layouts/Layout.astro";
import { laboratorios, getLabBySlug } from "../data/laboratorios";

export function getStaticPaths() {
    return laboratorios.map((lab) => ({ params: { lab: lab.slug } }));
}

const { lab: slug } = Astro.params;
const lab = getLabBySlug(slug!)!;

const sections = [
    { id: "practicas", label: "Prácticas", group: "Académico" },
    { id: "horario", label: "Horario", group: "Académico" },
    { id: "aulas", label: "Salas", group: "Académico" },
    { id: "carreras", label: "Carreras", group: "Académico" },
    { id: "mision", label: "Misión y Visión", group: "Institucional" },
    { id: "objetivos", label: "Objetivos", group: "Institucional" },
    { id: "valores", label: "Valores", group: "Institucional" },
    { id: "historia", label: "Historia", group: "Institucional" },
    { id: "organizacion", label: "Organización", group: "Recursos" },
    { id: "equipo", label: "Equipamiento", group: "Recursos" },
    { id: "certificaciones", label: "Certificaciones", group: "Actividades" },
    { id: "eventos", label: "Eventos", group: "Actividades" },
    { id: "concursos", label: "Concursos", group: "Actividades" },
    { id: "congresos", label: "Congresos", group: "Actividades" },
    { id: "reglamento", label: "Reglamento", group: "Info" },
    { id: "ubicacion", label: "Ubicación", group: "Info" },
    { id: "contacto", label: "Contacto", group: "Info" },
    { id: "buzon", label: "Buzón", group: "Info" },
];

const groups = [
    "Académico",
    "Institucional",
    "Recursos",
    "Actividades",
    "Info",
];
---

<Layout title={`${lab.nombre} – ITS`} description={lab.descripcionCorta}>
    <!-- ═══════════════════════════════════════════════════════════ HERO -->
    <section
        class="lab-hero"
        style={`--c: ${lab.color}; --cs: ${lab.colorSecundario}`}
    >
        <canvas class="lab-canvas" id="lab-canvas"></canvas>
        <div class="hero-grid-bg"></div>
        <div class="hero-orb ho-1"></div>
        <div class="hero-orb ho-2"></div>

        <div class="hero-inner">
            <a href="/" class="back-link">
                <svg
                    width="15"
                    height="15"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                >
                    <path d="M19 12H5M12 5l-7 7 7 7"></path>
                </svg>
                Todos los laboratorios
            </a>

            <div class="hero-tag">ITS Saltillo</div>
            <h1 class="hero-name">{lab.nombre}</h1>
            <p class="hero-desc">{lab.descripcionCorta}</p>

            <div class="hero-stats">
                <div class="hstat">
                    <span class="hstat-n">{lab.practicas.length}</span>
                    <span class="hstat-l">Prácticas</span>
                </div>
                <div class="hstat-sep"></div>
                <div class="hstat">
                    <span class="hstat-n">{lab.equipo.length}</span>
                    <span class="hstat-l">Equipos</span>
                </div>
                <div class="hstat-sep"></div>
                <div class="hstat">
                    <span class="hstat-n">{lab.aulas.length}</span>
                    <span class="hstat-l">Salas</span>
                </div>
                <div class="hstat-sep"></div>
                <div class="hstat">
                    <span class="hstat-n">{lab.carreras.length}</span>
                    <span class="hstat-l">Carreras</span>
                </div>
            </div>

            <div class="hero-pills">
                <span class="hpill">
                    <svg
                        width="13"
                        height="13"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                    >
                        <circle cx="12" cy="12" r="10"></circle><polyline
                            points="12 6 12 12 16 14"></polyline>
                    </svg>
                    {lab.horario.lunesViernes}
                </span>
                <span class="hpill">
                    <svg
                        width="13"
                        height="13"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                    >
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"
                        ></path><circle cx="12" cy="7" r="4"></circle>
                    </svg>
                    {lab.contacto.responsable}
                </span>
                <span class="hpill">
                    <svg
                        width="13"
                        height="13"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                    >
                        <path
                            d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                        ></path><polyline points="22,6 12,13 2,6"></polyline>
                    </svg>
                    {lab.contacto.email}
                </span>
            </div>
        </div>

        <!-- Scroll hint -->
        <div class="hero-scroll-hint">
            <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="rgba(255,255,255,0.5)"
                stroke-width="2"
            >
                <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
        </div>
    </section>

    <!-- ════════════════════════════════════════════════════ TAB NAV -->
    <nav class="tab-nav" id="tab-nav">
        <!-- Row 1: group pills -->
        <div class="nav-groups">
            <div class="ng-inner">
                {
                    groups.map((g, gi) => (
                        <button
                            class={`group-btn${gi === 0 ? " active" : ""}`}
                            data-group={g}
                            style={`--c: ${lab.color}`}
                        >
                            {g}
                        </button>
                    ))
                }
            </div>
        </div>
        <!-- Row 2: section tabs for active group -->
        <div class="nav-sections">
            <div class="ns-inner">
                {
                    groups.map((g, gi) => (
                        <div
                            class={`section-row${gi === 0 ? " active" : ""}`}
                            data-group={g}
                        >
                            {sections
                                .filter((s) => s.group === g)
                                .map((s, si) => (
                                    <button
                                        class={`tab-btn${
                                            gi === 0 && si === 0
                                                ? " active"
                                                : ""
                                        }`}
                                        data-target={s.id}
                                        style={`--c: ${lab.color}`}
                                    >
                                        {s.label}
                                    </button>
                                ))}
                        </div>
                    ))
                }
            </div>
        </div>
    </nav>

    <!-- ═══════════════════════════════════════════════════ PANELS -->
    <div class="panels-area container">
        <!-- PRACTICAS -->
        <section class="panel active" id="panel-practicas">
            <div class="panel-head">
                <span class="ph-bar" style={`background:${lab.color}`}></span>
                <h2>Prácticas de laboratorio</h2>
                <span
                    class="badge"
                    style={`background:${lab.color}18;color:${lab.color}`}
                >
                    {lab.practicas.length} prácticas
                </span>
            </div>
            <div class="practicas-grid">
                {
                    lab.practicas.map((p) => (
                        <div class="practica-card" style={`--c:${lab.color}`}>
                            <div
                                class="p-num"
                                style={`background:${lab.color}`}
                            >
                                {p.numero}
                            </div>
                            <div class="p-body">
                                <h3>{p.nombre}</h3>
                                <p>{p.descripcion}</p>
                                <div class="p-dur">
                                    <svg
                                        width="12"
                                        height="12"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                    >
                                        <circle cx="12" cy="12" r="10" />
                                        <polyline points="12 6 12 12 16 14" />
                                    </svg>
                                    {p.duracion}
                                </div>
                            </div>
                        </div>
                    ))
                }
            </div>
        </section>

        <!-- HORARIO -->
        <section class="panel" id="panel-horario">
            <div class="panel-head">
                <span class="ph-bar" style={`background:${lab.color}`}></span>
                <h2>Horario de atención</h2>
            </div>
            <div class="horario-cards">
                <div class="h-card" style={`--c:${lab.color}`}>
                    <div class="h-day">Lunes a Viernes</div>
                    <div class="h-time">{lab.horario.lunesViernes}</div>
                </div>
                <div class="h-card" style={`--c:${lab.color}`}>
                    <div class="h-day">Sábado</div>
                    <div class="h-time">{lab.horario.sabado}</div>
                </div>
                <div class="h-card closed">
                    <div class="h-day">Domingo</div>
                    <div class="h-time">{lab.horario.domingo}</div>
                </div>
            </div>
            <div class="obs-box">
                <svg
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke={lab.color}
                    stroke-width="2"
                >
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="12" y1="8" x2="12" y2="12"></line>
                    <line x1="12" y1="16" x2="12.01" y2="16"></line>
                </svg>
                <p>{lab.horario.observaciones}</p>
            </div>

            {
                lab.horariosDetallados && (
                    <div class="horarios-detallados" style={`--c:${lab.color}`}>
                        <div class="hd-header">
                            <h3>Horarios por aula</h3>
                            <span class="hd-periodo">
                                {lab.horariosDetallados.periodo}
                            </span>
                        </div>

                        <div class="hd-aula-tabs" id="hd-aula-tabs">
                            {lab.horariosDetallados.aulas.map((a, i) => (
                                <button
                                    class={`hd-aula-btn${
                                        i === 0 ? " active" : ""
                                    }`}
                                    data-aula-idx={i}
                                    style={`--c:${lab.color}`}
                                >
                                    {a.aula}
                                </button>
                            ))}
                        </div>

                        <div class="hd-tables-wrap" id="hd-tables-wrap">
                            {lab.horariosDetallados.aulas.map((a, ai) => (
                                <div
                                    class={`hd-table-container${
                                        ai === 0 ? " active" : ""
                                    }`}
                                    data-aula-table={ai}
                                >
                                    <div class="hd-table-scroll">
                                        <table class="hd-table">
                                            <thead>
                                                <tr>
                                                    <th class="hd-th-hora">
                                                        Hora
                                                    </th>
                                                    <th>Lunes</th>
                                                    <th>Martes</th>
                                                    <th>Miércoles</th>
                                                    <th>Jueves</th>
                                                    <th>Viernes</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                {a.horario.map((franja) => (
                                                    <tr>
                                                        <td class="hd-td-hora">
                                                            {franja.hora}
                                                        </td>
                                                        {(
                                                            [
                                                                "lunes",
                                                                "martes",
                                                                "miercoles",
                                                                "jueves",
                                                                "viernes",
                                                            ] as const
                                                        ).map((dia) => {
                                                            const celda =
                                                                franja[dia];
                                                            if (
                                                                celda ===
                                                                    null ||
                                                                celda ===
                                                                    undefined
                                                            ) {
                                                                return (
                                                                    <td class="hd-td-libre">
                                                                        <span class="hd-libre">
                                                                            —
                                                                        </span>
                                                                    </td>
                                                                );
                                                            }
                                                            if (
                                                                typeof celda ===
                                                                "string"
                                                            ) {
                                                                const isLibre =
                                                                    celda
                                                                        .toLowerCase()
                                                                        .includes(
                                                                            "libre"
                                                                        );
                                                                return (
                                                                    <td
                                                                        class={
                                                                            isLibre
                                                                                ? "hd-td-libre"
                                                                                : "hd-td-clase"
                                                                        }
                                                                    >
                                                                        <span
                                                                            class={
                                                                                isLibre
                                                                                    ? "hd-libre"
                                                                                    : "hd-materia"
                                                                            }
                                                                        >
                                                                            {
                                                                                celda
                                                                            }
                                                                        </span>
                                                                    </td>
                                                                );
                                                            }
                                                            return (
                                                                <td class="hd-td-clase">
                                                                    <div class="hd-clase-info">
                                                                        <span class="hd-materia">
                                                                            {
                                                                                celda.materia
                                                                            }
                                                                        </span>
                                                                        {celda.grupo && (
                                                                            <span class="hd-grupo">
                                                                                {
                                                                                    celda.grupo
                                                                                }
                                                                            </span>
                                                                        )}
                                                                        <span class="hd-maestro">
                                                                            {
                                                                                celda.maestro
                                                                            }
                                                                        </span>
                                                                    </div>
                                                                </td>
                                                            );
                                                        })}
                                                    </tr>
                                                ))}
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            ))}
                        </div>

                        {lab.horariosDetallados.programa_asesorias && (
                            <details class="hd-asesorias-details">
                                <summary style={`--c:${lab.color}`}>
                                    <svg
                                        width="16"
                                        height="16"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                    >
                                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                                        <circle cx="9" cy="7" r="4" />
                                        <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" />
                                    </svg>
                                    Programa de asesorías —{" "}
                                    {
                                        lab.horariosDetallados
                                            .programa_asesorias.periodo
                                    }
                                </summary>
                                <div class="hd-asesorias-grid">
                                    {lab.horariosDetallados.programa_asesorias.maestros.map(
                                        (m) => (
                                            <div class="hd-asesoria-card">
                                                <div
                                                    class="hd-asesoria-nombre"
                                                    style={`--c:${lab.color}`}
                                                >
                                                    {m.nombre}
                                                </div>
                                                <div class="hd-asesoria-body">
                                                    {m.asesorias_materias && (
                                                        <div class="hd-asesoria-item">
                                                            <span class="hd-asesoria-label">
                                                                Asesorías
                                                                materias
                                                            </span>
                                                            {Array.isArray(
                                                                m.asesorias_materias
                                                            ) ? (
                                                                m.asesorias_materias.map(
                                                                    (a) => (
                                                                        <span class="hd-asesoria-val">
                                                                            {
                                                                                a.hora
                                                                            }{" "}
                                                                            hrs
                                                                            —{" "}
                                                                            {
                                                                                a.dias
                                                                            }
                                                                        </span>
                                                                    )
                                                                )
                                                            ) : (
                                                                <span class="hd-asesoria-val">
                                                                    {
                                                                        m
                                                                            .asesorias_materias
                                                                            .hora
                                                                    }{" "}
                                                                    hrs —{" "}
                                                                    {
                                                                        m
                                                                            .asesorias_materias
                                                                            .dias
                                                                    }
                                                                </span>
                                                            )}
                                                        </div>
                                                    )}
                                                    {m.asesorias_residencias && (
                                                        <div class="hd-asesoria-item">
                                                            <span class="hd-asesoria-label">
                                                                Asesorías
                                                                residencias
                                                            </span>
                                                            {Array.isArray(
                                                                m.asesorias_residencias
                                                            ) ? (
                                                                m.asesorias_residencias.map(
                                                                    (a) => (
                                                                        <span class="hd-asesoria-val">
                                                                            {
                                                                                a.hora
                                                                            }{" "}
                                                                            hrs
                                                                            —{" "}
                                                                            {
                                                                                a.dias
                                                                            }
                                                                        </span>
                                                                    )
                                                                )
                                                            ) : (
                                                                <span class="hd-asesoria-val">
                                                                    {
                                                                        m
                                                                            .asesorias_residencias
                                                                            .hora
                                                                    }{" "}
                                                                    hrs —{" "}
                                                                    {
                                                                        m
                                                                            .asesorias_residencias
                                                                            .dias
                                                                    }
                                                                </span>
                                                            )}
                                                        </div>
                                                    )}
                                                    {m.tutorias && (
                                                        <div class="hd-asesoria-item">
                                                            <span class="hd-asesoria-label">
                                                                Tutorías
                                                            </span>
                                                            {Array.isArray(
                                                                m.tutorias
                                                            ) ? (
                                                                m.tutorias.map(
                                                                    (a) => (
                                                                        <span class="hd-asesoria-val">
                                                                            {
                                                                                a.hora
                                                                            }{" "}
                                                                            hrs
                                                                            —{" "}
                                                                            {
                                                                                a.dias
                                                                            }
                                                                        </span>
                                                                    )
                                                                )
                                                            ) : (
                                                                <span class="hd-asesoria-val">
                                                                    {
                                                                        m
                                                                            .tutorias
                                                                            .hora
                                                                    }{" "}
                                                                    hrs —{" "}
                                                                    {
                                                                        m
                                                                            .tutorias
                                                                            .dias
                                                                    }
                                                                </span>
                                                            )}
                                                        </div>
                                                    )}
                                                    <div class="hd-asesoria-item">
                                                        <span class="hd-asesoria-label">
                                                            Lugar
                                                        </span>
                                                        <span class="hd-asesoria-val">
                                                            {m.lugar}
                                                        </span>
                                                    </div>
                                                </div>
                                            </div>
                                        )
                                    )}
                                </div>
                            </details>
                        )}
                    </div>
                )
            }
        </section>

        <!-- SALAS -->
        <section class="panel" id="panel-aulas">
            <div class="panel-head">
                <span class="ph-bar" style={`background:${lab.color}`}></span>
                <h2>Salas disponibles</h2>
            </div>
            <div class="aulas-list">
                {
                    lab.aulas.map((a) => (
                        <div class="aula-row">
                            <div
                                class="aula-id"
                                style={`background:${lab.color}`}
                            >
                                {a.id}
                            </div>
                            <div class="aula-info">
                                <strong>{a.nombre}</strong>
                                <p>{a.descripcion}</p>
                            </div>
                            <div class="aula-cap">
                                <svg
                                    width="14"
                                    height="14"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                >
                                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                                    <circle cx="9" cy="7" r="4" />
                                </svg>
                                {a.capacidad}
                            </div>
                        </div>
                    ))
                }
            </div>
        </section>

        <!-- CARRERAS Y MATERIAS -->
        <section class="panel" id="panel-carreras">
            <div class="panel-head">
                <span class="ph-bar" style={`background:${lab.color}`}></span>
                <h2>Carreras y materias</h2>
            </div>
            <div class="two-col">
                <div class="list-box">
                    <h3 style={`color:${lab.color}`}>Carreras vinculadas</h3>
                    <ul class="dot-list" style={`--c:${lab.color}`}>
                        {lab.carreras.map((c) => <li>{c}</li>)}
                    </ul>
                </div>
                <div class="list-box">
                    <h3 style={`color:${lab.color}`}>
                        Materias que usan el lab
                    </h3>
                    <ul class="dot-list" style={`--c:${lab.color}`}>
                        {lab.materias.map((m) => <li>{m}</li>)}
                    </ul>
                </div>
            </div>
        </section>

        <!-- MISION Y VISION -->
        <section class="panel" id="panel-mision">
            <div class="panel-head">
                <span class="ph-bar" style={`background:${lab.color}`}></span>
                <h2>Misión y Visión</h2>
            </div>
            <div class="mv-grid">
                <div class="mv-block" style={`border-left-color:${lab.color}`}>
                    <div class="mv-label">Misión</div>
                    <p>{lab.mision}</p>
                </div>
                <div class="mv-block" style={`border-left-color:${lab.color}`}>
                    <div class="mv-label">Visión</div>
                    <p>{lab.vision}</p>
                </div>
            </div>
        </section>

        <!-- OBJETIVOS -->
        <section class="panel" id="panel-objetivos">
            <div class="panel-head">
                <span class="ph-bar" style={`background:${lab.color}`}></span>
                <h2>Objetivos</h2>
            </div>
            <ol class="obj-list" style={`--c:${lab.color}`}>
                {lab.objetivos.map((o) => <li>{o}</li>)}
            </ol>
        </section>

        <!-- VALORES -->
        <section class="panel" id="panel-valores">
            <div class="panel-head">
                <span class="ph-bar" style={`background:${lab.color}`}></span>
                <h2>Valores institucionales</h2>
            </div>
            <div class="valores-grid">
                {
                    lab.valores.map((v, i) => (
                        <div class="valor-tile" style={`--c:${lab.color}`}>
                            <div class="v-num">
                                {String(i + 1).padStart(2, "0")}
                            </div>
                            <p>{v}</p>
                        </div>
                    ))
                }
            </div>
        </section>

        <!-- HISTORIA -->
        <section class="panel" id="panel-historia">
            <div class="panel-head">
                <span class="ph-bar" style={`background:${lab.color}`}></span>
                <h2>Historia del laboratorio</h2>
            </div>
            <div class="historia-box" style={`border-left-color:${lab.color}`}>
                <p>{lab.historia}</p>
            </div>
            <div class="ubicacion-row">
                <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke={lab.color}
                    stroke-width="2"
                >
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
                    ></path>
                    <circle cx="12" cy="10" r="3"></circle>
                </svg>
                <span>{lab.ubicacion}</span>
            </div>
        </section>

        <!-- ORGANIZACION -->
        <section class="panel" id="panel-organizacion">
            <div class="panel-head">
                <span class="ph-bar" style={`background:${lab.color}`}></span>
                <h2>Estructura organizacional</h2>
            </div>
            <div class="org-tree">
                <div class="org-jefe" style={`border-color:${lab.color}`}>
                    <div class="org-avatar" style={`background:${lab.color}`}>
                        {lab.organizacion.jefe.charAt(0)}
                    </div>
                    <div>
