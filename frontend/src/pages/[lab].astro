---
import Layout from "../layouts/Layout.astro";
import { laboratorios, getLabBySlug } from "../data/laboratorios";
import conexionesSistemas from "../data/conexiones_sistemas_ITS.json";
import horariosSistemas from "../data/horarios_ITS_Sistemas.json";

export function getStaticPaths() {
    return laboratorios.map((lab) => ({ params: { lab: lab.slug } }));
}

const { lab: slug } = Astro.params;
const lab = getLabBySlug(slug!)!;

// ── Sistemas: rich materias list with carrera connections ──
const _carreraKeyMap: Record<string, string> = {
    "Ing. Mecatrónica": "Ingeniería Mecatrónica",
    "Ing. Electrónica": "Ingeniería Electrónica",
    "Ing. Eléctrica": "Ingeniería Eléctrica",
    "Ing. Industrial": "Ingeniería Industrial",
    "Ing. Mecánica": "Ingeniería Mecánica",
    "Ing. Gestión Empresarial": "Ingeniería en Gestión Empresarial",
    "Ing. Sistemas": "Ingeniería en Sistemas Computacionales",
};
const _sistCarreras = [
    "Ingeniería en Sistemas Computacionales",
    "Ingeniería Industrial",
    "Ingeniería Mecatrónica",
    "Ingeniería en Gestión Empresarial",
    "Ingeniería Mecánica",
    "Ingeniería Eléctrica",
    "Ingeniería Electrónica",
    "Ingeniería en Materiales",
];
// Extract unique materia abbreviations from the real schedule
const _horarioMaterias = new Set<string>();
const _days = ["lunes", "martes", "miercoles", "jueves", "viernes"] as const;
for (const aula of (horariosSistemas as any).aulas) {
    for (const slot of aula.horario) {
        for (const day of _days) {
            if (slot[day] && typeof slot[day] === "object" && slot[day].materia) {
                _horarioMaterias.add(slot[day].materia as string);
            }
        }
    }
}

const sistemasMateriasRich = (conexionesSistemas.materias as any[])
    .filter((m: any) => {
        // Check if any abbreviation variant of this materia appears in the schedule
        const variants: string[] = (m.abreviacion as string)
            .split("/")
            .map((s: string) => s.trim());
        return variants.some((v) => _horarioMaterias.has(v));
    })
    .map((m: any) => {
        const carreras = new Set<string>();
        if ((m.grupos_sistemas?.length ?? 0) > 0 || m.tipo === "exclusiva") {
            carreras.add("Ingeniería en Sistemas Computacionales");
        }
        for (const con of m.conexiones ?? []) {
            if (con.tipo_relacion === "tematica_relacionada") continue;
            const c: string = con.carrera;
            if (c === "Ing. Sistemas") {
                carreras.add("Ingeniería en Sistemas Computacionales");
            } else if (c === "Todas las ingenierías") {
                _sistCarreras.forEach((x) => carreras.add(x));
            } else {
                const full = _carreraKeyMap[c];
                if (full) carreras.add(full);
            }
        }
        if (m.tipo === "externa_impartida_en_sistemas" && m.carrera_origen) {
            (m.carrera_origen as string).split("/").map((s: string) => s.trim()).forEach((orig: string) => {
                const full = _carreraKeyMap[orig];
                if (full) carreras.add(full);
            });
        }
        return { nombre: m.nombre as string, carreras: Array.from(carreras) };
    });

