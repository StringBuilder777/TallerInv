<script>
    // ── ATROPOS 3D TILT (Historia) ─────────────────────────────────────────
    import Atropos from "atropos";
    import "atropos/css";

    (function initAtropos() {
        const el = document.getElementById("historia-atropos");
        if (!el) return;
        Atropos({
            el,
            activeOffset: 40,
            shadowScale: 1.05,
            rotateXMax: 12,
            rotateYMax: 12,
        });
    })();

    // ── LIGHTBOX GALERÍA ─────────────────────────────────────────────
    (function initGallery() {
        // Crear el lightbox en el DOM
        const lb = document.createElement("div");
        lb.className = "gallery-lightbox";
        lb.id = "gallery-lightbox";
        lb.innerHTML = `
            <button class="gallery-lightbox-close" id="lb-close" aria-label="Cerrar">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
            </button>
            <button class="gallery-lightbox-nav gallery-lightbox-prev" id="lb-prev" aria-label="Anterior">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <polyline points="15 18 9 12 15 6"/>
                </svg>
            </button>
            <img id="lb-img" src="" alt="" />
            <p class="gallery-lightbox-caption" id="lb-caption"></p>
            <button class="gallery-lightbox-nav gallery-lightbox-next" id="lb-next" aria-label="Siguiente">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <polyline points="9 18 15 12 9 6"/>
                </svg>
            </button>
        `;
        document.body.appendChild(lb);

        let items: { src: string; caption: string }[] = [];
        let current = 0;

        function open(gallery: HTMLElement, idx: number) {
            items = Array.from(
                gallery.querySelectorAll<HTMLElement>(".gallery-item")
            ).map((el) => ({
                src: el.dataset.src || "",
                caption: el.dataset.caption || "",
            }));
            current = idx;
            show();
        }

        function show() {
            const lb = document.getElementById("gallery-lightbox")!;
            const img = document.getElementById("lb-img") as HTMLImageElement;
            const cap = document.getElementById("lb-caption")!;
            img.src = items[current].src;
            cap.textContent = `${items[current].caption} (${current + 1}/${
                items.length
            })`;
            lb.classList.add("open");
            document.body.style.overflow = "hidden";
        }

        function close() {
            document
                .getElementById("gallery-lightbox")!
                .classList.remove("open");
            document.body.style.overflow = "";
        }

        document.getElementById("lb-close")?.addEventListener("click", close);
        lb.addEventListener("click", (e) => {
            if (e.target === lb) close();
        });
        document.getElementById("lb-prev")?.addEventListener("click", () => {
            current = (current - 1 + items.length) % items.length;
            show();
        });
        document.getElementById("lb-next")?.addEventListener("click", () => {
            current = (current + 1) % items.length;
            show();
        });
        document.addEventListener("keydown", (e) => {
            if (
                !document
                    .getElementById("gallery-lightbox")!
                    .classList.contains("open")
            )
                return;
            if (e.key === "Escape") close();
            if (e.key === "ArrowLeft") {
                current = (current - 1 + items.length) % items.length;
                show();
            }
            if (e.key === "ArrowRight") {
                current = (current + 1) % items.length;
                show();
            }
        });

        document
            .querySelectorAll<HTMLElement>(".lab-gallery")
            .forEach((gallery) => {
                gallery
                    .querySelectorAll<HTMLElement>(".gallery-atropos")
                    .forEach((card, idx) => {
                        // init Atropos 3D on each card
                        Atropos({
                            el: card,
                            activeOffset: 30,
                            shadowScale: 1.04,
                            rotateXMax: 14,
                            rotateYMax: 14,
                        });
                        // open lightbox on click of inner area
                        card.querySelector(
                            ".gallery-atropos-inner"
                        )?.addEventListener("click", () => {
                            // rebuild items from this gallery's atropos cards
                            items = Array.from(
                                gallery.querySelectorAll<HTMLElement>(
                                    ".gallery-atropos"
                                )
                            ).map((el) => ({
                                src: el.dataset.src || "",
                                caption: el.dataset.caption || "",
                            }));
                            current = idx;
                            show();
                        });
                    });
                // fallback for non-atropos .gallery-item (kept for safety)
                gallery
                    .querySelectorAll<HTMLElement>(".gallery-item")
                    .forEach((item, idx) => {
                        item.addEventListener("click", () =>
                            open(gallery, idx)
                        );
                    });
            });
    })();

    // ── HERO PARTICLES ─────────────────────────────────────────────────────
    (function () {
        const canvas = document.getElementById(
            "lab-canvas"
        ) as HTMLCanvasElement | null;
        if (!canvas) return;
        const ctx = canvas.getContext("2d")!;
        const N = 50,
            D = 110;
        let W = 0,
            H = 0;
        interface P {
            x: number;
            y: number;
            vx: number;
            vy: number;
            r: number;
            a: number;
        }
        let pts: P[] = [];

        function init() {
            W = canvas!.width = canvas!.offsetWidth;
            H = canvas!.height = canvas!.offsetHeight;
            pts = Array.from({ length: N }, () => ({
                x: Math.random() * W,
                y: Math.random() * H,
                vx: (Math.random() - 0.5) * 0.35,
                vy: (Math.random() - 0.5) * 0.35,
                r: Math.random() * 1.6 + 0.4,
                a: Math.random() * 0.45 + 0.1,
            }));
        }

        function frame() {
            ctx.clearRect(0, 0, W, H);
            for (const p of pts) {
                p.x += p.vx;
                p.y += p.vy;
                if (p.x < 0 || p.x > W) p.vx *= -1;
                if (p.y < 0 || p.y > H) p.vy *= -1;
                ctx.beginPath();
                ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
                ctx.fillStyle = `rgba(255,255,255,${p.a})`;
                ctx.fill();
            }
            for (let i = 0; i < N; i++) {
                for (let j = i + 1; j < N; j++) {
                    const dx = pts[i].x - pts[j].x,
                        dy = pts[i].y - pts[j].y;
                    const d = Math.sqrt(dx * dx + dy * dy);
                    if (d < D) {
                        ctx.beginPath();
                        ctx.moveTo(pts[i].x, pts[i].y);
                        ctx.lineTo(pts[j].x, pts[j].y);
                        ctx.strokeStyle = `rgba(255,255,255,${
                            0.08 * (1 - d / D)
                        })`;
                        ctx.lineWidth = 0.5;
                        ctx.stroke();
                    }
                }
            }
            requestAnimationFrame(frame);
        }

        init();
        frame();
        window.addEventListener("resize", init);
    })();

    // ── NAVIGATION ─────────────────────────────────────────────────────────
    const groupBtns =
        document.querySelectorAll<HTMLButtonElement>(".group-btn");
    const sectionRows = document.querySelectorAll<HTMLElement>(".section-row");
    const tabBtns = document.querySelectorAll<HTMLButtonElement>(".tab-btn");
    const panels = document.querySelectorAll<HTMLElement>(".panel");

    function activatePanel(btn: HTMLButtonElement) {
        const target = btn.dataset.target!;
        tabBtns.forEach((b) => b.classList.remove("active"));
        panels.forEach((p) => p.classList.remove("active"));
        btn.classList.add("active");
        document.getElementById(`panel-${target}`)?.classList.add("active");
        btn.scrollIntoView({
            behavior: "smooth",
            block: "nearest",
            inline: "center",
        });
        const tabNav = document.getElementById("tab-nav");
        const navBottom =
            (tabNav?.getBoundingClientRect().bottom ?? 0) + window.scrollY;
        window.scrollTo({ top: navBottom - 10, behavior: "smooth" });
    }

    groupBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
            const group = btn.dataset.group!;
            groupBtns.forEach((b) => b.classList.remove("active"));
            sectionRows.forEach((r) => r.classList.remove("active"));
            btn.classList.add("active");
            const row = document.querySelector<HTMLElement>(
                `.section-row[data-group="${group}"]`
            );
            row?.classList.add("active");
            // Auto-activate first tab in the new group
            const firstTab = row?.querySelector<HTMLButtonElement>(".tab-btn");
            if (firstTab) activatePanel(firstTab);
        });
    });

    tabBtns.forEach((btn) => {
        btn.addEventListener("click", () => activatePanel(btn));
    });

    // ── BUZÓN ──────────────────────────────────────────────────────────────
    document.getElementById("sug-btn")?.addEventListener("click", () => {
        const ta = document.getElementById("sug-text") as HTMLTextAreaElement;
        const btn = document.getElementById("sug-btn") as HTMLButtonElement;
        if (ta.value.trim()) {
            btn.textContent = "¡Enviado correctamente!";
            btn.disabled = true;
            ta.value = "";
            setTimeout(() => {
                btn.textContent = "Enviar sugerencia";
                btn.disabled = false;
            }, 3000);
        } else {
            ta.focus();
        }
    });

    // ── HORARIOS DETALLADOS – TAB SWITCHING ─────────────────────────────────────
    const hdAulaTabs = document.getElementById("hd-aula-tabs");
    if (hdAulaTabs) {
        const aulaBtns =
            hdAulaTabs.querySelectorAll<HTMLButtonElement>(".hd-aula-btn");
        const aulaContainers = document.querySelectorAll<HTMLElement>(
            ".hd-table-container"
        );

        aulaBtns.forEach((btn) => {
            btn.addEventListener("click", () => {
                const idx = btn.dataset.aulaIdx;
                aulaBtns.forEach((b) => b.classList.remove("active"));
                aulaContainers.forEach((c) => c.classList.remove("active"));
                btn.classList.add("active");
                const target = document.querySelector<HTMLElement>(
                    `.hd-table-container[data-aula-table="${idx}"]`
                );
                target?.classList.add("active");
            });
        });
    }

    // ── SALONES EN HORARIO (estado en tiempo real) ──────────────────────────
    (function initSalonesEstado() {
        const widget = document.getElementById("salones-estado");
        if (!widget) return;

        const raw = widget.dataset.horarios;
        if (!raw) return;
        const aulas: Array<{
            aula: string;
            horario: Array<{
                hora: string;
                lunes: any;
                martes: any;
                miercoles: any;
                jueves: any;
                viernes: any;
            }>;
        }> = JSON.parse(raw);

        const diasMap: Record<number, keyof typeof aulas[0]["horario"][0]> = {
            1: "lunes",
            2: "martes",
            3: "miercoles",
            4: "jueves",
            5: "viernes",
        };

        function getClaseActual(aulaData: typeof aulas[0]) {
            const now = new Date();
            const dow = now.getDay(); // 0=dom, 1=lun ... 6=sab
            const diaKey = diasMap[dow];
            if (!diaKey) return null; // fin de semana

            const h = now.getHours();
            // Buscar la franja cuya hora en punto <= hora actual < siguiente franja
            for (let i = 0; i < aulaData.horario.length; i++) {
                const franjaH = parseInt(
                    aulaData.horario[i].hora.split(":")[0],
                    10
                );
                const nextH =
                    i + 1 < aulaData.horario.length
                        ? parseInt(
                              aulaData.horario[i + 1].hora.split(":")[0],
                              10
                          )
                        : franjaH + 1;
                if (h >= franjaH && h < nextH) {
                    const celda = (aulaData.horario[i] as any)[diaKey];
                    return celda;
                }
            }
            return null;
        }

        function isLibre(celda: any): boolean {
            if (celda === null || celda === undefined) return true;
            if (typeof celda === "string")
                return celda.toLowerCase().includes("libre");
            return false;
        }

        function render() {
            const seHora = document.getElementById("se-hora");
            const seGrid = document.getElementById("se-grid");
            if (!seHora || !seGrid) return;

            const now = new Date();
            const dow = now.getDay();
            const pad = (n: number) => String(n).padStart(2, "0");
            seHora.textContent = `${pad(now.getHours())}:${pad(
                now.getMinutes()
            )}`;

            if (!diasMap[dow]) {
                seGrid.innerHTML = `<span class="se-fuera-horario">Fin de semana — laboratorio cerrado</span>`;
                return;
            }
            const h = now.getHours();
            // Lab abierto 7:00–21:00 aprox
            if (h < 7 || h >= 21) {
                seGrid.innerHTML = `<span class="se-fuera-horario">Fuera de horario de atención</span>`;
                return;
            }

            seGrid.innerHTML = aulas
                .map((a) => {
                    const celda = getClaseActual(a);
                    const libre = isLibre(celda);
                    const badge = libre ? "Libre" : "En clase";
                    const detail =
                        !libre && typeof celda === "object" && celda
                            ? celda.materia || ""
                            : "";
                    const grupo =
                        !libre && typeof celda === "object" && celda && celda.grupo
                            ? celda.grupo
                            : "";
                    return `
                    <div class="se-salon ${libre ? "libre" : "ocupado"}">
                        <span class="se-salon-id">${a.aula}</span>
                        <span class="se-salon-badge">${badge}</span>
                        ${
                            detail
                                ? `<span class="se-salon-clase">${detail}</span>`
                                : ""
                        }
                        ${
                            grupo
                                ? `<span class="se-salon-grupo">${grupo}</span>`
                                : ""
                        }
                    </div>`;
                })
                .join("");
        }

        render();
        setInterval(render, 60_000); // actualizar cada minuto
    })();

    // ── LEAFLET MAP ─────────────────────────────────────────────────────────
    (function initMap() {
        const mapEl = document.getElementById("leaflet-map");
        if (!mapEl) return;

        // Load Leaflet CSS
        const linkEl = document.createElement("link");
        linkEl.rel = "stylesheet";
        linkEl.href = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.css";
        document.head.appendChild(linkEl);

        // Load Leaflet JS
        const scriptEl = document.createElement("script");
        scriptEl.src = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.js";
        scriptEl.onload = function () {
            const L = (window as any).L;
            if (!L) return;

            const lat = 25.4449611;
            const lng = -100.9953923;
            const isDark =
                document.documentElement.getAttribute("data-theme") === "dark";

            const lightTiles =
                "https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png";
            const darkTiles =
                "https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png";

            const map = L.map("leaflet-map", {
                center: [lat, lng],
                zoom: 16,
                scrollWheelZoom: false,
            });

            const tileLayer = L.tileLayer(isDark ? darkTiles : lightTiles, {
                attribution:
                    '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/">CARTO</a>',
                maxZoom: 19,
            }).addTo(map);

            // Custom marker with popup
            const marker = L.marker([lat, lng]).addTo(map);
            marker
                .bindPopup(
                    '<div style="text-align:center;padding:4px 8px;"><strong>Instituto Tecnológico de Saltillo</strong><br><span style="font-size:0.85em;color:#666;">Campus ITS – Blvd. V. Carranza #2400, Col. Tecnológico, Saltillo</span></div>'
                )
                .openPopup();

            // Listen for theme changes to swap tiles
            const observer = new MutationObserver(function () {
                const dark =
                    document.documentElement.getAttribute("data-theme") ===
                    "dark";
                tileLayer.setUrl(dark ? darkTiles : lightTiles);
            });
            observer.observe(document.documentElement, {
                attributes: true,
                attributeFilter: ["data-theme"],
            });

            // Fix map size when panel becomes visible
            const ubPanel = document.getElementById("panel-ubicacion");
            if (ubPanel) {
                const resizeObserver = new ResizeObserver(() => {
                    if (ubPanel.classList.contains("active")) {
                        setTimeout(() => map.invalidateSize(), 100);
                    }
                });
                resizeObserver.observe(ubPanel);

                // Also trigger on tab click
                document.querySelectorAll(".tab-btn").forEach((tabBtn) => {
                    tabBtn.addEventListener("click", () => {
                        setTimeout(() => {
                            if (ubPanel.classList.contains("active")) {
                                map.invalidateSize();
                            }
                        }, 200);
                    });
                });
            }
        };
        document.head.appendChild(scriptEl);
    })();

    /* ── EXPAND – Práctica cards (click en toda la tarjeta) ──────────────────────────────────── */
    document.querySelectorAll('.practica-card.pc-rich').forEach(card => {
        card.addEventListener('click', (e) => {
            // Evitar que se active si se hace click en un link, imagen o details/summary dentro
            const target = e.target as HTMLElement;
            if (target.tagName === 'A' || target.tagName === 'IMG') return;
            if (target.tagName === 'SUMMARY' || target.closest('summary')) return;
            if (target.closest('details')) return;
            
            const expanded = card.querySelector('.p-expanded') as HTMLElement | null;
            if (!expanded) return;
            
            const isOpen = expanded.classList.contains('open');
            
            // Cerrar todas las demás tarjetas expandidas
            document.querySelectorAll('.practica-card.pc-rich').forEach(otherCard => {
                if (otherCard !== card) {
                    const otherExpanded = otherCard.querySelector('.p-expanded') as HTMLElement | null;
                    if (otherExpanded) {
                        otherExpanded.classList.remove('open');
                        otherCard.classList.remove('expanded');
                    }
                }
            });
            
            // Toggle la tarjeta actual
            expanded.classList.toggle('open', !isOpen);
            card.classList.toggle('expanded', !isOpen);
        });
        
        // Agregar cursor pointer para indicar que es clickeable
        (card as HTMLElement).style.cursor = 'pointer';
    });

    /* ── HOVER FILTER – Sistemas (data-carreras + FLIP reorder) ───── */
    (function () {
        const panel = document.getElementById('carreras-materias-panel');
        if (!panel) return;

        const materiaItems = Array.from(panel.querySelectorAll('.materia-item')) as HTMLElement[];
        const hasSistemas = materiaItems.some(li => li.hasAttribute('data-carreras'));
        if (!hasSistemas) return;

        const carreraItems = Array.from(panel.querySelectorAll('.carrera-item')) as HTMLElement[];
        const matList = panel.querySelector('.materias-list') as HTMLElement | null;
        if (!matList) return;

        // Make the list a flex column so CSS order works
        matList.style.display = 'flex';
        matList.style.flexDirection = 'column';

        function applyFilter(carreraText: string) {
            // First: snapshot positions
            const before = new Map<HTMLElement, number>();
            materiaItems.forEach(li => before.set(li, li.getBoundingClientRect().top));

            // Apply order
            materiaItems.forEach(li => {
                const attr = li.getAttribute('data-carreras') || '';
                const matches = carreraText
                    ? attr.split('|').some(c => c === carreraText)
                    : false;
                li.classList.toggle('match', matches);
                li.style.order = carreraText ? (matches ? '-1' : '1') : '';
            });

            // FLIP: invert & play
            materiaItems.forEach(li => {
                const delta = (before.get(li) ?? 0) - li.getBoundingClientRect().top;
                if (delta === 0) return;
                li.style.transition = 'none';
                li.style.transform = `translateY(${delta}px)`;
                requestAnimationFrame(() => {
                    li.style.transition = 'transform 0.28s cubic-bezier(0.4,0,0.2,1), opacity 0.2s';
                    li.style.transform = '';
                });
            });
        }

        function clearFilter() {
            // Snapshot before restore
            const before = new Map<HTMLElement, number>();
            materiaItems.forEach(li => before.set(li, li.getBoundingClientRect().top));

            materiaItems.forEach(li => {
                li.classList.remove('match');
                li.style.order = '';
            });

            // FLIP back
            materiaItems.forEach(li => {
                const delta = (before.get(li) ?? 0) - li.getBoundingClientRect().top;
                if (delta === 0) return;
                li.style.transition = 'none';
                li.style.transform = `translateY(${delta}px)`;
                requestAnimationFrame(() => {
                    li.style.transition = 'transform 0.28s cubic-bezier(0.4,0,0.2,1), opacity 0.2s';
                    li.style.transform = '';
                });
            });
        }

        carreraItems.forEach(carreraLi => {
            carreraLi.addEventListener('mouseenter', () => {
                const carreraText = carreraLi.getAttribute('data-carrera') || '';
                panel.classList.add('is-filtering');
                carreraItems.forEach(li => li.classList.remove('active-carrera'));
                carreraLi.classList.add('active-carrera');
                applyFilter(carreraText);
            });
            carreraLi.addEventListener('mouseleave', () => {
                setTimeout(() => {
                    if (!panel.matches(':hover')) {
                        panel.classList.remove('is-filtering');
                        carreraItems.forEach(li => li.classList.remove('active-carrera'));
                        clearFilter();
                    }
                }, 80);
            });
        });

        panel.addEventListener('mouseleave', () => {
            panel.classList.remove('is-filtering');
            carreraItems.forEach(li => li.classList.remove('active-carrera'));
            clearFilter();
        });
    })();

    /* ── HOVER FILTER – Carreras ↔ Materias (física/química + FLIP) ── */
    (function () {
        const panel = document.getElementById('carreras-materias-panel');
        if (!panel) return;

        const carreraItems = Array.from(panel.querySelectorAll('.carrera-item')) as HTMLElement[];
        const materiaItems = Array.from(panel.querySelectorAll('.materia-item')) as HTMLElement[];

        const hasSuffix = materiaItems.some(li => li.textContent && li.textContent.includes(' – '));
        if (!hasSuffix) return;

        const matList = panel.querySelector('.materias-list') as HTMLElement | null;
        if (matList) {
            matList.style.display = 'flex';
            matList.style.flexDirection = 'column';
        }

        function flipReorder(matchFn: (li: HTMLElement) => boolean) {
            const before = new Map<HTMLElement, number>();
            materiaItems.forEach(li => before.set(li, li.getBoundingClientRect().top));

            materiaItems.forEach(li => {
                const matches = matchFn(li);
                li.classList.toggle('match', matches);
                li.style.order = matches ? '-1' : '1';
            });

            materiaItems.forEach(li => {
                const delta = (before.get(li) ?? 0) - li.getBoundingClientRect().top;
                if (delta === 0) return;
                li.style.transition = 'none';
                li.style.transform = `translateY(${delta}px)`;
                requestAnimationFrame(() => {
                    li.style.transition = 'transform 0.28s cubic-bezier(0.4,0,0.2,1), opacity 0.2s';
                    li.style.transform = '';
                });
            });
        }

        function clearReorder() {
            const before = new Map<HTMLElement, number>();
            materiaItems.forEach(li => before.set(li, li.getBoundingClientRect().top));

            materiaItems.forEach(li => {
                li.classList.remove('match');
                li.style.order = '';
            });

            materiaItems.forEach(li => {
                const delta = (before.get(li) ?? 0) - li.getBoundingClientRect().top;
                if (delta === 0) return;
                li.style.transition = 'none';
                li.style.transform = `translateY(${delta}px)`;
                requestAnimationFrame(() => {
                    li.style.transition = 'transform 0.28s cubic-bezier(0.4,0,0.2,1), opacity 0.2s';
                    li.style.transform = '';
                });
            });
        }

        carreraItems.forEach(carreraLi => {
            carreraLi.addEventListener('mouseenter', () => {
                const carreraText = carreraLi.getAttribute('data-carrera') || '';
                const keyword = carreraText.replace(/^Ingeniería\s+(en\s+|de\s+)?/i, '').trim();
                panel.classList.add('is-filtering');
                carreraItems.forEach(li => li.classList.remove('active-carrera'));
                carreraLi.classList.add('active-carrera');
                flipReorder(li => {
                    const text = li.textContent || '';
                    return text.includes(keyword) || text.includes(carreraText);
                });
            });

            carreraLi.addEventListener('mouseleave', () => {
                setTimeout(() => {
                    if (!panel.matches(':hover')) {
                        panel.classList.remove('is-filtering');
                        carreraItems.forEach(li => li.classList.remove('active-carrera'));
                        clearReorder();
                    }
                }, 80);
            });
        });

        panel.addEventListener('mouseleave', () => {
            panel.classList.remove('is-filtering');
            carreraItems.forEach(li => li.classList.remove('active-carrera'));
            clearReorder();
        });
    })();
</script>
