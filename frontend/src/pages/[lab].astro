    }
    .hd-aula-btn:hover {
        color: var(--text-primary);
        border-color: var(--c);
    }
    .hd-aula-btn.active {
        background: var(--c);
        color: #fff;
        border-color: var(--c);
        box-shadow: 0 2px 10px color-mix(in srgb, var(--c) 35%, transparent);
    }

    .hd-table-container {
        display: none;
        animation: hdFadeIn 0.3s ease;
    }
    .hd-table-container.active {
        display: block;
    }
    @keyframes hdFadeIn {
        from {
            opacity: 0;
            transform: translateY(6px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .hd-table-scroll {
        overflow-x: auto;
        border: 1px solid var(--border);
        border-radius: 14px;
        background: var(--bg-card);
    }

    .hd-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.8rem;
        min-width: 700px;
    }
    .hd-table thead {
        background: color-mix(in srgb, var(--c) 10%, var(--bg-surface));
    }
    .hd-table th {
        padding: 0.75rem 0.65rem;
        text-align: center;
        font-weight: 700;
        font-size: 0.76rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--c);
        border-bottom: 2px solid var(--border);
        white-space: nowrap;
    }
    .hd-th-hora {
        width: 70px;
        text-align: center;
    }
    .hd-table td {
        padding: 0.55rem 0.5rem;
        border-bottom: 1px solid var(--border);
        vertical-align: top;
        text-align: center;
    }
    .hd-table tbody tr:last-child td {
        border-bottom: none;
    }
    .hd-table tbody tr:hover {
        background: color-mix(in srgb, var(--c) 4%, transparent);
    }

    .hd-td-hora {
        font-weight: 700;
        color: var(--text-primary);
        font-size: 0.82rem;
        white-space: nowrap;
        text-align: center;
        background: color-mix(in srgb, var(--c) 5%, var(--bg-surface));
    }
    .hd-td-libre {
        color: var(--text-secondary);
        opacity: 0.5;
    }
    .hd-libre {
        font-size: 0.78rem;
        color: var(--text-secondary);
    }
    .hd-td-clase {
        background: color-mix(in srgb, var(--c) 5%, transparent);
    }

    .hd-clase-info {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
        text-align: left;
    }
    .hd-materia {
        font-weight: 600;
        font-size: 0.78rem;
        color: var(--text-primary);
        line-height: 1.25;
    }
    .hd-grupo {
        font-size: 0.7rem;
        font-weight: 700;
        color: var(--c);
        background: color-mix(in srgb, var(--c) 12%, transparent);
        padding: 0.1rem 0.35rem;
        border-radius: 4px;
        display: inline-block;
        width: fit-content;
    }
    .hd-maestro {
        font-size: 0.7rem;
        color: var(--text-secondary);
        line-height: 1.3;
    }

    /* Asesorías collapsible */
    .hd-asesorias-details {
        margin-top: 1.5rem;
    }
    .hd-asesorias-details summary {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
        font-weight: 600;
        font-size: 0.93rem;
        color: var(--c);
        padding: 0.75rem 1rem;
        background: color-mix(in srgb, var(--c) 8%, var(--bg-card));
        border: 1px solid color-mix(in srgb, var(--c) 20%, var(--border));
        border-radius: 12px;
        transition: background 0.2s;
        list-style: none;
    }
    .hd-asesorias-details summary::-webkit-details-marker {
        display: none;
    }
    .hd-asesorias-details summary::after {
        content: "+";
        margin-left: auto;
        font-size: 1.2rem;
        font-weight: 400;
        transition: transform 0.2s;
    }
    .hd-asesorias-details[open] summary::after {
        content: "-";
    }
    .hd-asesorias-details summary:hover {
        background: color-mix(in srgb, var(--c) 14%, var(--bg-card));
    }

    .hd-asesorias-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 0.75rem;
        margin-top: 1rem;
        padding: 0.25rem;
    }
    .hd-asesoria-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        transition: box-shadow 0.2s, background 0.3s;
    }
    .hd-asesoria-card:hover {
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    }
    .hd-asesoria-nombre {
        padding: 0.6rem 0.9rem;
        font-size: 0.85rem;
        font-weight: 700;
        color: var(--text-primary);
        background: color-mix(in srgb, var(--c) 8%, var(--bg-surface));
        border-bottom: 1px solid var(--border);
    }
    .hd-asesoria-body {
        padding: 0.65rem 0.9rem;
    }
    .hd-asesoria-item {
        display: flex;
        flex-direction: column;
        gap: 0.1rem;
        padding: 0.25rem 0;
        border-bottom: 1px solid var(--border);
    }
    .hd-asesoria-item:last-child {
        border-bottom: none;
    }
    .hd-asesoria-label {
        font-size: 0.68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--text-secondary);
    }
    .hd-asesoria-val {
        font-size: 0.8rem;
        color: var(--text-primary);
        line-height: 1.4;
    }

    /* ── SALAS ────────────────────────────────────────────────────── */
    .aulas-list {
        display: grid;
        gap: 0.75rem;
    }
    .aula-row {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1.1rem 1.4rem;
        transition: background 0.3s, border-color 0.3s;
    }
    .aula-id {
        flex-shrink: 0;
        color: #fff;
        font-weight: 700;
        font-size: 0.8rem;
        padding: 0.3rem 0.65rem;
        border-radius: 7px;
        margin-top: 2px;
    }
    .aula-info {
        flex: 1;
    }
    .aula-info strong {
        font-size: 0.95rem;
        color: var(--text-primary);
        display: block;
        margin-bottom: 0.2rem;
    }
    .aula-info p {
        font-size: 0.87rem;
        color: var(--text-secondary);
        line-height: 1.6;
        margin: 0;
    }
    .aula-cap {
        display: flex;
        align-items: center;
        gap: 0.3rem;
        font-size: 0.8rem;
        color: var(--text-secondary);
        flex-shrink: 0;
        background: var(--bg-surface);
        padding: 0.3rem 0.7rem;
        border-radius: 100px;
        white-space: nowrap;
    }

    /* ── CARRERAS ─────────────────────────────────────────────────── */
    .two-col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
    }
    .list-box {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 1.5rem;
        transition: background 0.3s, border-color 0.3s;
    }
    .list-box h3 {
        font-size: 1rem;
        margin-bottom: 0.75rem;
    }
    .dot-list {
        list-style: none;
        display: grid;
        gap: 0.45rem;
    }
    .dot-list li {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        font-size: 0.9rem;
        color: var(--text-primary);
        padding: 0.35rem 0;
        border-bottom: 1px solid var(--border);
    }
    .dot-list li:last-child {
        border-bottom: none;
    }
    .dot-list li::before {
        content: "";
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--c);
        flex-shrink: 0;
    }

    /* ── MISION/VISION ────────────────────────────────────────────── */
    .mv-grid {
        display: grid;
        gap: 1.25rem;
    }
    .mv-block {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-left: 4px solid;
        border-radius: 14px;
        padding: 1.5rem 1.75rem;
        transition: background 0.3s, border-color 0.3s;
    }
    .mv-label {
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--text-secondary);
        font-weight: 600;
        margin-bottom: 0.5rem;
    }
    .mv-block p {
        color: var(--text-secondary);
        line-height: 1.8;
        font-size: 0.95rem;
        margin: 0;
    }

    /* ── OBJETIVOS ────────────────────────────────────────────────── */
    .obj-list {
        list-style: none;
        counter-reset: obj;
        display: grid;
        gap: 0.75rem;
    }
    .obj-list li {
        counter-increment: obj;
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1rem 1.25rem;
        font-size: 0.93rem;
        color: var(--text-primary);
        line-height: 1.6;
        transition: background 0.3s;
    }
    .obj-list li::before {
        content: counter(obj, decimal-leading-zero);
        color: var(--c);
        font-weight: 800;
        font-size: 1.1rem;
        flex-shrink: 0;
        line-height: 1.4;
    }

    /* ── VALORES ──────────────────────────────────────────────────── */
    .valores-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
        gap: 1rem;
    }
    .valor-tile {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-top: 3px solid var(--c);
        border-radius: 14px;
        padding: 1.35rem 1rem;
        transition: box-shadow 0.2s, background 0.3s;
    }
    .valor-tile:hover {
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
    }
    .v-num {
        font-size: 2.2rem;
        font-weight: 800;
        color: var(--c);
        opacity: 0.25;
        line-height: 1;
        margin-bottom: 0.45rem;
        font-family: "Poppins", sans-serif;
    }
    .valor-tile p {
        font-size: 0.88rem;
        color: var(--text-primary);
        line-height: 1.6;
        margin: 0;
    }

    /* ── HISTORIA ─────────────────────────────────────────────────── */
    .historia-box {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-left: 4px solid;
        border-radius: 14px;
        padding: 1.75rem;
        margin-bottom: 1rem;
        transition: background 0.3s;
    }
    .historia-box p {
        color: var(--text-secondary);
        line-height: 1.85;
        font-size: 0.95rem;
        margin: 0;
    }
    .ubicacion-row {
        display: flex;
        align-items: flex-start;
        gap: 0.6rem;
        font-size: 0.9rem;
        color: var(--text-secondary);
    }

    /* ── ORGANIZACION ─────────────────────────────────────────────── */
    .org-tree {
        display: grid;
        gap: 1.25rem;
    }
    .org-jefe {
        display: flex;
        align-items: center;
        gap: 1rem;
        background: var(--bg-card);
        border: 2px solid;
        border-radius: 14px;
        padding: 1.25rem 1.5rem;
        max-width: 520px;
        transition: background 0.3s;
    }
    .org-avatar {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        color: #fff;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        flex-shrink: 0;
    }
    .org-avatar.sm {
        width: 34px;
        height: 34px;
        font-size: 0.9rem;
        background: var(--bg-surface);
        color: var(--text-secondary);
    }
    .org-role {
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--text-secondary);
    }
    .org-name {
        font-size: 1rem;
        font-weight: 600;
        color: var(--text-primary);
    }
    .org-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.25rem;
    }
    .org-col {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1.25rem;
        transition: background 0.3s;
    }
    .org-col-title {
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--text-secondary);
        margin-bottom: 0.75rem;
        font-weight: 600;
    }
    .org-person {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        font-size: 0.9rem;
        color: var(--text-primary);
        padding: 0.35rem 0;
        border-bottom: 1px solid var(--border);
    }
    .org-person:last-child {
        border-bottom: none;
    }

    /* ── EQUIPO ───────────────────────────────────────────────────── */
    .equipo-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 1rem;
    }
    .eq-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1.5rem 1.5rem 1.25rem;
        position: relative;
        transition: box-shadow 0.2s, background 0.3s, border-color 0.2s;
    }
    .eq-card:hover {
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
        border-color: color-mix(in srgb, var(--c) 30%, transparent);
    }
    .eq-qty {
        position: absolute;
        top: -10px;
        right: 1rem;
        color: #fff;
        font-weight: 700;
        font-size: 0.78rem;
        padding: 0.2rem 0.55rem;
        border-radius: 100px;
    }
    .eq-card h4 {
        font-size: 0.93rem;
        color: var(--text-primary);
        margin-bottom: 0.35rem;
    }
    .eq-card p {
        font-size: 0.84rem;
        color: var(--text-secondary);
        line-height: 1.6;
        margin: 0;
    }

    /* ── CERTIFICACIONES ──────────────────────────────────────────── */
    .cert-list {
        display: grid;
        gap: 1rem;
    }
    .cert-row {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1.25rem 1.5rem;
        transition: background 0.3s;
    }
    .cert-check {
        flex-shrink: 0;
        width: 36px;
        height: 36px;
        border: 2px solid;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.95rem;
    }
    .cert-info strong {
        font-size: 0.95rem;
        color: var(--text-primary);
        display: block;
        margin-bottom: 0.15rem;
    }
    .cert-org {
        font-size: 0.78rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        display: block;
        margin-bottom: 0.3rem;
    }
    .cert-info p {
        font-size: 0.87rem;
        color: var(--text-secondary);
        line-height: 1.6;
        margin: 0;
    }

    /* ── EVENTOS / CONCURSOS / CONGRESOS ──────────────────────────── */
    .event-list {
        display: grid;
        gap: 1rem;
    }
    .event-row {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1.25rem 1.5rem;
        transition: background 0.3s;
    }
    .event-date {
        flex-shrink: 0;
        color: #fff;
        font-weight: 600;
        font-size: 0.78rem;
        padding: 0.3rem 0.7rem;
        border-radius: 8px;
        white-space: nowrap;
        margin-top: 2px;
    }
    .event-date.nivel {
        background: #6b7280;
    }
    .event-info strong {
        font-size: 0.95rem;
        color: var(--text-primary);
        display: block;
        margin-bottom: 0.25rem;
    }
    .event-info p {
        font-size: 0.87rem;
        color: var(--text-secondary);
        line-height: 1.6;
        margin: 0;
    }

    /* ── REGLAMENTO ───────────────────────────────────────────────── */
    .reg-list {
        display: grid;
        gap: 0.75rem;
    }
    .reg-row {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1rem 1.25rem;
        transition: background 0.3s;
    }
    .reg-n {
        font-size: 1.3rem;
        font-weight: 800;
        flex-shrink: 0;
        line-height: 1.4;
    }
    .reg-row p {
        font-size: 0.92rem;
        color: var(--text-primary);
        line-height: 1.6;
        margin: 0;
    }

    /* ── UBICACION ────────────────────────────────────────────────── */
    .ubic-card {
        display: flex;
        align-items: flex-start;
        gap: 1.25rem;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-left: 4px solid;
        border-radius: 16px;
        padding: 2rem;
        transition: background 0.3s;
    }
    .ubic-card svg {
        flex-shrink: 0;
        margin-top: 2px;
    }
    .ubic-card strong {
        font-size: 1rem;
        color: var(--text-primary);
        display: block;
        margin-bottom: 0.35rem;
    }
    .ubic-card p {
        font-size: 0.9rem;
        color: var(--text-secondary);
        line-height: 1.6;
        margin-bottom: 1rem;
    }
    .map-btn {
        display: inline-block;
        color: #fff;
        text-decoration: none;
        padding: 0.55rem 1.25rem;
        border-radius: 8px;
        font-size: 0.9rem;
        font-weight: 600;
        transition: opacity 0.2s, background 0.2s;
    }
    .map-btn:hover {
        opacity: 0.85;
    }
    .map-btn.outline {
        background: transparent;
        border: 2px solid;
    }
    .map-btn.outline:hover {
        opacity: 0.7;
    }
    .ubic-btns {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }
    .map-container {
        margin-top: 1.5rem;
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid var(--border);
        height: 400px;
        background: var(--bg-surface);
    }
    .map-container .leaflet-control-attribution {
        font-size: 0.7rem;
        background: rgba(255, 255, 255, 0.8) !important;
    }
    [data-theme="dark"] .map-container .leaflet-control-attribution {
        background: rgba(0, 0, 0, 0.6) !important;
        color: rgba(255, 255, 255, 0.6);
    }
    [data-theme="dark"] .map-container .leaflet-control-attribution a {
        color: rgba(255, 255, 255, 0.6);
    }

    /* ── CONTACTO ─────────────────────────────────────────────────── */
    .contacto-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
    }
    .contact-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-top: 3px solid var(--c);
        border-radius: 14px;
        padding: 1.35rem;
        transition: background 0.3s, border-color 0.3s;
    }
    .cc-label {
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--text-secondary);
        margin-bottom: 0.3rem;
        font-weight: 600;
    }
    .cc-val {
        font-size: 0.97rem;
        font-weight: 600;
        color: var(--text-primary);
    }
    .cc-val.link {
        text-decoration: none;
    }
    .cc-val.link:hover {
        text-decoration: underline;
    }

    /* ── BUZON ────────────────────────────────────────────────────── */
    .buzon-wrap {
        max-width: 660px;
    }
    .buzon-desc {
        color: var(--text-secondary);
        font-size: 0.93rem;
        line-height: 1.7;
        margin-bottom: 1.5rem;
    }
    .buzon-form {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 1.5rem;
        transition: background 0.3s;
    }
    .buzon-form textarea {
        width: 100%;
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 0.75rem 1rem;
        font-family: inherit;
        font-size: 0.9rem;
        color: var(--text-primary);
        background: var(--bg-surface);
        resize: vertical;
        margin-bottom: 0.75rem;
        outline: none;
        transition: border-color 0.2s, background 0.3s, color 0.3s;
    }
    .buzon-form textarea:focus {
        border-color: var(--c, #2563eb);
    }
    .buzon-row {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }
    .buzon-row input {
        flex: 1;
        min-width: 150px;
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 0.6rem 1rem;
        font-family: inherit;
        font-size: 0.9rem;
        color: var(--text-primary);
        background: var(--bg-surface);
        outline: none;
        transition: border-color 0.2s, background 0.3s, color 0.3s;
    }
    .buzon-row input:focus {
        border-color: var(--c, #2563eb);
    }
    #sug-btn {
        color: #fff;
        border: none;
        padding: 0.65rem 1.4rem;
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        transition: opacity 0.2s;
        font-family: inherit;
    }
    #sug-btn:hover {
        opacity: 0.88;
    }

    /* ── RESPONSIVE ───────────────────────────────────────────────── */
    @media (max-width: 900px) {
        .lab-hero {
            padding: 5rem 0 4rem;
        }
        .hero-inner {
            padding: 0 1.25rem;
        }
        .hero-stats {
            padding: 1rem 1.25rem;
            gap: 0;
        }
        .hstat-sep {
            margin: 0 0.6rem;
            height: 30px;
        }
        .hstat-n {
            font-size: 1.5rem;
        }
        .horario-cards {
            grid-template-columns: 1fr;
        }
        .two-col {
            grid-template-columns: 1fr;
        }
        .org-row {
            grid-template-columns: 1fr;
        }
    }
    @media (max-width: 640px) {
        .practicas-grid {
            grid-template-columns: 1fr;
        }
        .practica-card {
            flex-direction: column;
            gap: 0.75rem;
        }
        .aula-row {
            flex-wrap: wrap;
        }
        .hero-stats {
            flex-wrap: wrap;
            gap: 0.75rem;
        }
        .hstat-sep {
            display: none;
        }
        .hstat {
            min-width: 70px;
            flex: none;
        }
        .panels-area {
            padding-top: 1.5rem;
        }
        .hd-asesorias-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<script>
    // ── HERO PARTICLES ─────────────────────────────────────────────────────
    (function () {
        const canvas = document.getElementById(
            "lab-canvas"
        ) as HTMLCanvasElement | null;
        if (!canvas) return;
        const ctx = canvas.getContext("2d")!;
        const N = 50,
            D = 110;
        let W = 0,
            H = 0;
        interface P {
            x: number;
            y: number;
            vx: number;
            vy: number;
            r: number;
            a: number;
        }
        let pts: P[] = [];

        function init() {
            W = canvas!.width = canvas!.offsetWidth;
            H = canvas!.height = canvas!.offsetHeight;
            pts = Array.from({ length: N }, () => ({
                x: Math.random() * W,
                y: Math.random() * H,
                vx: (Math.random() - 0.5) * 0.35,
                vy: (Math.random() - 0.5) * 0.35,
                r: Math.random() * 1.6 + 0.4,
                a: Math.random() * 0.45 + 0.1,
            }));
        }

        function frame() {
            ctx.clearRect(0, 0, W, H);
            for (const p of pts) {
                p.x += p.vx;
                p.y += p.vy;
                if (p.x < 0 || p.x > W) p.vx *= -1;
                if (p.y < 0 || p.y > H) p.vy *= -1;
                ctx.beginPath();
                ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
                ctx.fillStyle = `rgba(255,255,255,${p.a})`;
                ctx.fill();
            }
            for (let i = 0; i < N; i++) {
                for (let j = i + 1; j < N; j++) {
                    const dx = pts[i].x - pts[j].x,
                        dy = pts[i].y - pts[j].y;
                    const d = Math.sqrt(dx * dx + dy * dy);
                    if (d < D) {
                        ctx.beginPath();
                        ctx.moveTo(pts[i].x, pts[i].y);
                        ctx.lineTo(pts[j].x, pts[j].y);
                        ctx.strokeStyle = `rgba(255,255,255,${
                            0.08 * (1 - d / D)
                        })`;
                        ctx.lineWidth = 0.5;
                        ctx.stroke();
                    }
                }
            }
            requestAnimationFrame(frame);
        }

        init();
        frame();
        window.addEventListener("resize", init);
    })();

    // ── NAVIGATION ─────────────────────────────────────────────────────────
    const groupBtns =
        document.querySelectorAll<HTMLButtonElement>(".group-btn");
    const sectionRows = document.querySelectorAll<HTMLElement>(".section-row");
    const tabBtns = document.querySelectorAll<HTMLButtonElement>(".tab-btn");
    const panels = document.querySelectorAll<HTMLElement>(".panel");

    function activatePanel(btn: HTMLButtonElement) {
        const target = btn.dataset.target!;
        tabBtns.forEach((b) => b.classList.remove("active"));
        panels.forEach((p) => p.classList.remove("active"));
        btn.classList.add("active");
        document.getElementById(`panel-${target}`)?.classList.add("active");
        btn.scrollIntoView({
            behavior: "smooth",
            block: "nearest",
            inline: "center",
        });
        const tabNav = document.getElementById("tab-nav");
        const navBottom =
            (tabNav?.getBoundingClientRect().bottom ?? 0) + window.scrollY;
        window.scrollTo({ top: navBottom - 10, behavior: "smooth" });
    }

    groupBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
            const group = btn.dataset.group!;
            groupBtns.forEach((b) => b.classList.remove("active"));
            sectionRows.forEach((r) => r.classList.remove("active"));
            btn.classList.add("active");
            const row = document.querySelector<HTMLElement>(
                `.section-row[data-group="${group}"]`
            );
            row?.classList.add("active");
            // Auto-activate first tab in the new group
            const firstTab = row?.querySelector<HTMLButtonElement>(".tab-btn");
            if (firstTab) activatePanel(firstTab);
        });
    });

    tabBtns.forEach((btn) => {
        btn.addEventListener("click", () => activatePanel(btn));
    });

    // ── BUZÓN ──────────────────────────────────────────────────────────────
    document.getElementById("sug-btn")?.addEventListener("click", () => {
        const ta = document.getElementById("sug-text") as HTMLTextAreaElement;
        const btn = document.getElementById("sug-btn") as HTMLButtonElement;
        if (ta.value.trim()) {
            btn.textContent = "¡Enviado correctamente!";
            btn.disabled = true;
            ta.value = "";
            setTimeout(() => {
                btn.textContent = "Enviar sugerencia";
                btn.disabled = false;
            }, 3000);
        } else {
            ta.focus();
        }
    });

    // ── HORARIOS DETALLADOS – TAB SWITCHING ─────────────────────────────────
    const hdAulaTabs = document.getElementById("hd-aula-tabs");
    if (hdAulaTabs) {
        const aulaBtns =
            hdAulaTabs.querySelectorAll<HTMLButtonElement>(".hd-aula-btn");
        const aulaContainers = document.querySelectorAll<HTMLElement>(
            ".hd-table-container"
        );

        aulaBtns.forEach((btn) => {
            btn.addEventListener("click", () => {
                const idx = btn.dataset.aulaIdx;
                aulaBtns.forEach((b) => b.classList.remove("active"));
                aulaContainers.forEach((c) => c.classList.remove("active"));
                btn.classList.add("active");
                const target = document.querySelector<HTMLElement>(
                    `.hd-table-container[data-aula-table="${idx}"]`
                );
                target?.classList.add("active");
            });
        });
    }

    // ── LEAFLET MAP ─────────────────────────────────────────────────────────
    (function initMap() {
        const mapEl = document.getElementById("leaflet-map");
        if (!mapEl) return;

        // Load Leaflet CSS
        const linkEl = document.createElement("link");
        linkEl.rel = "stylesheet";
        linkEl.href = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.css";
        document.head.appendChild(linkEl);

        // Load Leaflet JS
        const scriptEl = document.createElement("script");
        scriptEl.src = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.js";
        scriptEl.onload = function () {
            const L = (window as any).L;
            if (!L) return;

            const lat = 25.4449611;
            const lng = -100.9953923;
            const isDark =
                document.documentElement.getAttribute("data-theme") === "dark";

            const lightTiles =
                "https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png";
            const darkTiles =
                "https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png";

            const map = L.map("leaflet-map", {
                center: [lat, lng],
                zoom: 16,
                scrollWheelZoom: false,
            });

            const tileLayer = L.tileLayer(isDark ? darkTiles : lightTiles, {
                attribution:
                    '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/">CARTO</a>',
                maxZoom: 19,
            }).addTo(map);

            // Custom marker with popup
            const marker = L.marker([lat, lng]).addTo(map);
            marker
                .bindPopup(
                    '<div style="text-align:center;padding:4px 8px;"><strong>Instituto Tecnológico de Saltillo</strong><br><span style="font-size:0.85em;color:#666;">Campus ITS – Blvd. V. Carranza #2400, Col. Tecnológico, Saltillo</span></div>'
                )
                .openPopup();

            // Listen for theme changes to swap tiles
            const observer = new MutationObserver(function () {
                const dark =
                    document.documentElement.getAttribute("data-theme") ===
                    "dark";
                tileLayer.setUrl(dark ? darkTiles : lightTiles);
            });
            observer.observe(document.documentElement, {
                attributes: true,
                attributeFilter: ["data-theme"],
            });

            // Fix map size when panel becomes visible
            const ubPanel = document.getElementById("panel-ubicacion");
            if (ubPanel) {
                const resizeObserver = new ResizeObserver(() => {
                    if (ubPanel.classList.contains("active")) {
                        setTimeout(() => map.invalidateSize(), 100);
                    }
                });
                resizeObserver.observe(ubPanel);

                // Also trigger on tab click
                document.querySelectorAll(".tab-btn").forEach((tabBtn) => {
                    tabBtn.addEventListener("click", () => {
                        setTimeout(() => {
                            if (ubPanel.classList.contains("active")) {
                                map.invalidateSize();
                            }
                        }, 200);
                    });
                });
            }
        };
        document.head.appendChild(scriptEl);
    })();
</script>
