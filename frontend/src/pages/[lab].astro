const practicasEnriquecidas = lab.practicas.map((p) => {
    const materiaNames = _practicaMateriaMap[p.numero] ?? [];
    const materiasRaw = (conexionesSistemas.materias as any[]).filter((m: any) =>
        materiaNames.includes(m.nombre as string)
    );
    // Build carrera → {color, short, materias[]} map
    // Solo incluir carreras que realmente cursan estas materias en el lab de sistemas
    const carreraMap = new Map<string, {color:string;short:string;materias:string[]}>();
    materiasRaw.forEach((m: any) => {
        const addC = (k: string) => {
            if (!_carreraColors[k]) return;
            if (!carreraMap.has(k)) carreraMap.set(k, {color:_carreraColors[k],short:_carreraShort[k],materias:[]});
            if (!carreraMap.get(k)!.materias.includes(m.nombre)) carreraMap.get(k)!.materias.push(m.nombre);
        };
        // Solo agregar Sistemas si tiene grupos o es exclusiva
        if ((m.grupos_sistemas?.length ?? 0) > 0 || m.tipo === "exclusiva") {
            addC("Ingeniería en Sistemas Computacionales");
        }
        // Para conexiones, solo agregar si NO es temática relacionada
        for (const con of m.conexiones ?? []) {
            if (con.tipo_relacion === "tematica_relacionada") continue;
            // Ignorar "Todas las ingenierías" para evitar mostrar carreras que no usan el lab
            if (con.carrera === "Todas las ingenierías") continue;
            const full = _carreraKeyMap[con.carrera]; 
            if (full) addC(full);
            if (con.carrera === "Ing. Sistemas") addC("Ingeniería en Sistemas Computacionales");
        }
        // Para materias externas, solo agregar si realmente se imparten en sistemas
        if (m.tipo === "externa_impartida_en_sistemas" && m.carrera_origen) {
            (m.carrera_origen as string).split("/").forEach((o:string)=>{ 
                const f=_carreraKeyMap[o.trim()]; 
                if(f) addC(f); 
            });
        }
    });
    
    // Obtener salones reales desde los horarios
    const salonesReales = new Set<string>();
    materiasRaw.forEach((m: any) => {
        const abrevs = (m.abreviacion as string).split("/").map((s: string) => s.trim());
        for (const aula of (horariosSistemas as any).aulas) {
            for (const slot of aula.horario) {
                for (const dia of _days) {
                    const celda = slot[dia];
                    if (celda && typeof celda === "object" && abrevs.includes(celda.materia)) {
                        salonesReales.add(aula.aula);
                    }
                }
            }
        }
    });
    
    // Grupos per materia (for expand) - con mini horario completo
    const materiasConGrupos = materiasRaw.map((m: any) => {
        const gs = [
            ...(m.grupos_sistemas ?? []),
            ...(m.conexiones ?? []).flatMap((c: any) => c.grupos ?? []),
        ].filter((v:string,i:number,a:string[])=>a.indexOf(v)===i);
        
        // Buscar información de horario completo para cada grupo
        const gruposConInfo = gs.map((grupo: string) => {
            const abrevs = (m.abreviacion as string).split("/").map((s: string) => s.trim());
            const horarioDias: Record<string, {salon: string, maestro: string, hora: string}[]> = {
                lunes: [],
                martes: [],
                miercoles: [],
                jueves: [],
                viernes: []
            };
            
            // Buscar todas las ocurrencias del grupo en los horarios
            for (const aula of (horariosSistemas as any).aulas) {
                for (const slot of aula.horario) {
                    for (const dia of _days) {
                        const celda = slot[dia];
                        if (celda && typeof celda === "object" && celda.grupo === grupo) {
                            // Verificar si la materia coincide
                            if (abrevs.includes(celda.materia)) {
                                horarioDias[dia].push({
                                    salon: aula.aula,
                                    maestro: celda.maestro,
                                    hora: slot.hora
                                });
                            }
                        }
                    }
                }
            }
            
            return {
                grupo,
                horario: horarioDias
            };
        });
        
        return { nombre: m.nombre as string, grupos: gruposConInfo };
    }).filter((m: any) => m.grupos.length > 0);

    return { 
        ...p, 
        carrerasConexion: Array.from(carreraMap.values()), 
        materiasConGrupos, 
        imgs: _practicaImgs[p.numero] ?? [],
        salones: Array.from(salonesReales).sort()
    };
});

const sections = [
