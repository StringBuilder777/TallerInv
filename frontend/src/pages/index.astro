---
import Layout from "../layouts/Layout.astro";
import { laboratorios } from "../data/laboratorios";
---

<Layout
    title="Laboratorios ITS – Instituto Tecnológico de Saltillo"
    description="Portal oficial de los laboratorios del Instituto Tecnológico de Saltillo."
>
    <!-- ── HERO ─────────────────────────────────────────────── -->
    <section class="hero">
        <canvas id="hero-canvas"></canvas>
        <div class="hero-grid"></div>
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="orb orb-3"></div>

        <div class="hero-content">
            <div class="hero-badge">
                <span class="badge-dot"></span>
                Instituto Tecnológico de Saltillo
            </div>
            <h1 class="hero-title">
                Laboratorios <span class="hero-accent">ITS</span>
            </h1>
            <p class="hero-subtitle">
                Espacios de aprendizaje de vanguardia donde la teoría se
                transforma en práctica. Descubre nuestros laboratorios
                especializados.
            </p>
            <div class="hero-actions">
                <a href="#labs" class="btn-hero">
                    Explorar laboratorios
                    <svg
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                    >
                        <path d="M7 17l9.2-9.2M17 17V7H7"></path>
                    </svg>
                </a>
                <a href="#features" class="btn-hero-outline">¿Por qué ITS?</a>
            </div>
        </div>

        <div class="hero-scroll" aria-hidden="true">
            <span>Explorar</span>
            <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
            >
                <path d="M7 10l5 5 5-5"></path>
            </svg>
        </div>
    </section>

    <!-- ── STATS STRIP ───────────────────────────────────────── -->
    <div class="stats-strip">
        <div class="container">
            <div class="strip-grid">
                <div class="strip-stat">
                    <span class="strip-num">3</span>
                    <span class="strip-info">
                        <strong>Laboratorios</strong>
                        <span>especializados</span>
                    </span>
                </div>
                <div class="strip-div"></div>
                <div class="strip-stat">
                    <span
                        class="strip-num"
                        data-target="40"
                        data-plus="true">40+</span
                    >
                    <span class="strip-info">
                        <strong>Prácticas</strong>
                        <span>curriculares</span>
                    </span>
                </div>
                <div class="strip-div"></div>
                <div class="strip-stat">
                    <span
                        class="strip-num"
                        data-target="250"
                        data-plus="true">250+</span
                    >
                    <span class="strip-info">
                        <strong>Equipos</strong>
                        <span>de laboratorio</span>
                    </span>
                </div>
                <div class="strip-div"></div>
                <div class="strip-stat">
                    <span class="strip-num">3</span>
                    <span class="strip-info">
                        <strong>Carreras</strong>
                        <span>vinculadas</span>
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- ── LABS ──────────────────────────────────────────────── -->
    <section class="labs-section" id="labs">
        <div class="container">
            <div class="section-header fade-up">
                <h2 class="section-title">Nuestros laboratorios</h2>
                <p class="section-sub">
                    Infraestructura de clase mundial para tu formación de
                    ingeniería
                </p>
            </div>
            <div class="labs-grid">
                {
                    laboratorios.map((lab, i) => (
                        <a
                            href={`/${lab.slug}`}
                            class="lab-card fade-up"
                            style={`--lc: ${lab.color}; --lcs: ${lab.colorSecundario}; transition-delay: ${i * 130}ms`}
                        >
                            <div class="card-head">
                                <div class="ch-bg-num">0{i + 1}</div>
                                <div class="ch-icon">{lab.icono}</div>
                            </div>
                            <div class="card-body">
                                <h3 class="card-title">{lab.nombre}</h3>
                                <p class="card-desc">{lab.descripcionCorta}</p>
                                <div class="card-footer">
                                    <div class="card-tags">
                                        <span class="ctag">
                                            {lab.practicas.length} prácticas
                                        </span>
                                        <span class="ctag">
                                            {lab.equipo.length} equipos
                                        </span>
                                        <span class="ctag">
                                            {lab.carreras.length} carreras
                                        </span>
                                    </div>
                                    <span
                                        class="card-cta-arrow"
                                        style={`color: ${lab.color}`}
                                    >
                                        Ver →
                                    </span>
                                </div>
                            </div>
                        </a>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- ── FEATURES ──────────────────────────────────────────── -->
    <section class="features-section" id="features">
        <div class="container">
            <div class="feat-header fade-up">
                <h2>¿Por qué elegir ITS?</h2>
                <p>Infraestructura y respaldo para tu desarrollo profesional</p>
            </div>
            <div class="feat-grid">
                <div class="feat fade-up">
                    <div class="feat-icon">
                        <svg
                            width="24"
                            height="24"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.8"
                        >
                            <path
                                d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                            ></path>
                        </svg>
                    </div>
                    <div class="feat-body">
                        <h3>Certificaciones internacionales</h3>
                        <p>
                            Centros autorizados por Cisco, Oracle, AWS y más
                            organismos globales de referencia.
                        </p>
                    </div>
                </div>
                <div class="feat fade-up" style="transition-delay:80ms">
                    <div class="feat-icon">
                        <svg
                            width="24"
                            height="24"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.8"
                        >
                            <rect x="2" y="3" width="20" height="14" rx="2"
                            ></rect>
                            <path d="M8 21h8M12 17v4"></path>
                        </svg>
                    </div>
                    <div class="feat-body">
                        <h3>Equipo de vanguardia</h3>
                        <p>
                            Instrumentos y maquinaria de última generación
                            actualizados continuamente para la industria real.
                        </p>
                    </div>
                </div>
                <div class="feat fade-up" style="transition-delay:160ms">
                    <div class="feat-icon">
                        <svg
                            width="24"
                            height="24"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.8"
                        >
                            <path
                                d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"
                            ></path>
                            <circle cx="9" cy="7" r="4"></circle>
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                        </svg>
                    </div>
                    <div class="feat-body">
                        <h3>Vinculación empresarial</h3>
                        <p>
                            Proyectos y prácticas en colaboración con empresas
                            líderes de la región de Coahuila.
                        </p>
                    </div>
                </div>
                <div class="feat fade-up" style="transition-delay:240ms">
                    <div class="feat-icon">
                        <svg
                            width="24"
                            height="24"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.8"
                        >
                            <path
                                d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6M18 9h1.5a2.5 2.5 0 0 0 0-5H18M4 22h16M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22M18 2H6v7a6 6 0 0 0 12 0V2z"
                            ></path>
                        </svg>
                    </div>
                    <div class="feat-body">
                        <h3>Congresos y concursos</h3>
                        <p>
                            Compite a nivel nacional e internacional e impulsa
                            tu perfil profesional y académico.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>

<script>
    // ── PARTICLE SYSTEM ───────────────────────────────────────────────────
    (function () {
        const canvas = document.getElementById(
            "hero-canvas"
        ) as HTMLCanvasElement | null;
        if (!canvas) return;
        const ctx = canvas.getContext("2d")!;
        const N = 65,
            D = 125;
        let W = 0,
            H = 0;
        interface P {
            x: number;
            y: number;
            vx: number;
            vy: number;
            r: number;
            a: number;
        }
        let pts: P[] = [];

        function init() {
            W = canvas!.width = canvas!.offsetWidth;
            H = canvas!.height = canvas!.offsetHeight;
            pts = Array.from({ length: N }, () => ({
                x: Math.random() * W,
                y: Math.random() * H,
                vx: (Math.random() - 0.5) * 0.38,
                vy: (Math.random() - 0.5) * 0.38,
                r: Math.random() * 1.6 + 0.6,
                a: Math.random() * 0.45 + 0.15,
            }));
        }

        function frame() {
            ctx.clearRect(0, 0, W, H);
            for (const p of pts) {
                p.x += p.vx;
                p.y += p.vy;
                if (p.x < 0 || p.x > W) p.vx *= -1;
                if (p.y < 0 || p.y > H) p.vy *= -1;
                ctx.beginPath();
                ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
                ctx.fillStyle = `rgba(255,255,255,${p.a})`;
                ctx.fill();
            }
            for (let i = 0; i < N; i++) {
                for (let j = i + 1; j < N; j++) {
                    const dx = pts[i].x - pts[j].x,
                        dy = pts[i].y - pts[j].y;
                    const d = Math.sqrt(dx * dx + dy * dy);
                    if (d < D) {
                        ctx.beginPath();
                        ctx.moveTo(pts[i].x, pts[i].y);
                        ctx.lineTo(pts[j].x, pts[j].y);
                        ctx.strokeStyle = `rgba(255,255,255,${0.09 * (1 - d / D)})`;
                        ctx.lineWidth = 0.5;
                        ctx.stroke();
                    }
                }
            }
            requestAnimationFrame(frame);
        }

        init();
        frame();
        window.addEventListener("resize", init);
    })();

    // ── COUNTER ANIMATION ─────────────────────────────────────────────────
    function countUp(el: HTMLElement) {
        const target = parseInt(el.dataset.target || el.textContent || "0");
        const hasPlus = el.dataset.plus === "true";
        if (!target) return;
        let startTs: number | null = null;
        const dur = 1600;
        function step(ts: number) {
            if (!startTs) startTs = ts;
            const p = Math.min((ts - startTs) / dur, 1);
            const ease = 1 - Math.pow(1 - p, 4);
            el.textContent = Math.round(ease * target) + (hasPlus ? "+" : "");
            if (p < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
    }

    // Trigger counters when stats strip comes into view
    const stripObserver = new IntersectionObserver(
        (entries) => {
            entries.forEach((e) => {
                if (e.isIntersecting) {
                    e.currentTarget
                        ?.querySelectorAll<HTMLElement>(
                            ".strip-num[data-target]"
                        )
                        .forEach(countUp);
                    stripObserver.disconnect();
                }
            });
        },
        { threshold: 0.5 }
    );
    const strip = document.querySelector(".stats-strip");
    if (strip) stripObserver.observe(strip);

    // ── SCROLL ANIMATIONS ─────────────────────────────────────────────────
    const observer = new IntersectionObserver(
        (entries) =>
            entries.forEach((e) => {
                if (e.isIntersecting) e.target.classList.add("in-view");
            }),
        { threshold: 0.08, rootMargin: "-20px" }
    );
    document
        .querySelectorAll(".fade-up")
        .forEach((el) => observer.observe(el));
</script>

<style>
    /* ── HERO ─────────────────────────────────────────────────── */
    .hero {
        position: relative;
        background: linear-gradient(
            135deg,
            #060d1a 0%,
            #0d1f4a 45%,
            #160f50 100%
        );
        min-height: 88vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        overflow: hidden;
    }

    #hero-canvas {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
        pointer-events: none;
    }

    .hero-grid {
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
            linear-gradient(
                90deg,
                rgba(255, 255, 255, 0.025) 1px,
                transparent 1px
            );
        background-size: 52px 52px;
        z-index: 0;
        pointer-events: none;
    }

    .orb {
        position: absolute;
        border-radius: 50%;
        filter: blur(90px);
        pointer-events: none;
        z-index: 0;
    }

    .orb-1 {
        width: 500px;
        height: 500px;
        background: radial-gradient(
            circle,
            rgba(59, 130, 246, 0.32) 0%,
            transparent 70%
        );
        top: -140px;
        left: -80px;
        animation: drift 14s ease-in-out infinite;
    }

    .orb-2 {
        width: 380px;
        height: 380px;
        background: radial-gradient(
            circle,
            rgba(245, 158, 11, 0.2) 0%,
            transparent 70%
        );
        bottom: -60px;
        right: 80px;
        animation: drift 17s ease-in-out infinite reverse;
    }

    .orb-3 {
        width: 320px;
        height: 320px;
        background: radial-gradient(
            circle,
            rgba(139, 92, 246, 0.22) 0%,
            transparent 70%
        );
        top: 42%;
        left: 58%;
        transform: translate(-50%, -50%);
        animation: drift 11s ease-in-out 3s infinite;
    }

    @keyframes drift {
        0%,
        100% {
            translate: 0 0;
        }
        33% {
            translate: 22px -18px;
        }
        66% {
            translate: -14px 12px;
        }
    }

    .hero-content {
        position: relative;
        z-index: 1;
        padding: 2rem;
        max-width: 820px;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.18);
        color: rgba(255, 255, 255, 0.9);
        padding: 0.45rem 1.2rem;
        border-radius: 100px;
        font-size: 0.82rem;
        font-weight: 500;
        letter-spacing: 0.04em;
        margin-bottom: 1.75rem;
        animation: fadeDown 0.6s ease both;
    }

    .badge-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: #4ade80;
        box-shadow: 0 0 8px #4ade80;
        animation: pulse-dot 2.2s ease-in-out infinite;
        flex-shrink: 0;
    }

    @keyframes pulse-dot {
        0%,
        100% {
            opacity: 1;
            transform: scale(1);
        }
        50% {
            opacity: 0.65;
            transform: scale(1.4);
        }
    }

    .hero-title {
        font-size: clamp(3rem, 8vw, 5.8rem);
        font-weight: 800;
        color: white;
        line-height: 1.08;
        margin-bottom: 1.1rem;
        animation: fadeDown 0.7s ease 0.1s both;
        letter-spacing: -0.025em;
    }

    .hero-accent {
        background: linear-gradient(135deg, #fbbf24 0%, #f97316 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .hero-subtitle {
        font-size: clamp(1rem, 2.5vw, 1.18rem);
        color: rgba(255, 255, 255, 0.72);
        max-width: 560px;
        margin: 0 auto 2rem;
        line-height: 1.75;
        animation: fadeDown 0.7s ease 0.2s both;
    }

    /* CTA Buttons */
    .hero-actions {
        display: flex;
        gap: 0.75rem;
        justify-content: center;
        flex-wrap: wrap;
        animation: fadeDown 0.7s ease 0.3s both;
    }

    .btn-hero {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: white;
        color: #0f172a;
        padding: 0.8rem 1.8rem;
        border-radius: 100px;
        font-weight: 700;
        font-size: 0.92rem;
        text-decoration: none;
        transition: all 0.25s;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.18);
    }

    .btn-hero:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25);
    }

    .btn-hero-outline {
        display: inline-flex;
        align-items: center;
        background: rgba(255, 255, 255, 0.1);
        color: rgba(255, 255, 255, 0.9);
        padding: 0.8rem 1.8rem;
        border-radius: 100px;
        font-weight: 600;
        font-size: 0.92rem;
        text-decoration: none;
        border: 1px solid rgba(255, 255, 255, 0.22);
        transition: all 0.25s;
        backdrop-filter: blur(8px);
    }

    .btn-hero-outline:hover {
        background: rgba(255, 255, 255, 0.18);
        border-color: rgba(255, 255, 255, 0.38);
        color: white;
    }

    .hero-scroll {
        position: absolute;
        bottom: 1.75rem;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.3rem;
        color: rgba(255, 255, 255, 0.4);
        font-size: 0.68rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        animation: bounce 2.8s ease-in-out infinite;
        z-index: 1;
    }

    /* ── STATS STRIP ───────────────────────────────────────────── */
    .stats-strip {
        background: var(--white);
        border-top: 1px solid var(--border-color);
        border-bottom: 1px solid var(--border-color);
        padding: 1.75rem 0;
        transition:
            background 0.3s,
            border-color 0.3s;
    }

    .strip-grid {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 2.5rem;
        flex-wrap: wrap;
    }

    .strip-stat {
        display: flex;
        align-items: center;
        gap: 0.9rem;
    }

    .strip-num {
        font-size: 2.1rem;
        font-weight: 800;
        color: var(--primary-color);
        font-family: "Poppins", sans-serif;
        line-height: 1;
        letter-spacing: -0.02em;
    }

    .strip-info {
        display: flex;
        flex-direction: column;
        line-height: 1.3;
    }

    .strip-info strong {
        font-size: 0.85rem;
        font-weight: 700;
        color: var(--text-dark);
    }

    .strip-info span {
        font-size: 0.72rem;
        color: var(--text-light);
        font-weight: 400;
    }

    .strip-div {
        width: 1px;
        height: 36px;
        background: var(--border-color);
        flex-shrink: 0;
    }

    /* ── LABS SECTION ──────────────────────────────────────────── */
    .labs-section {
        padding: 5.5rem 0;
    }

    .section-header {
        text-align: center;
        margin-bottom: 3rem;
    }

    .section-sub {
        color: var(--text-light);
        font-size: 1.05rem;
        margin-top: 0.4rem;
    }

    .labs-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 1.5rem;
    }

    /* Cards with colored header */
    .lab-card {
        border-radius: 22px;
        overflow: hidden;
        text-decoration: none;
        color: inherit;
        border: 1px solid var(--border-color);
        display: flex;
        flex-direction: column;
        transition:
            transform 0.35s ease,
            box-shadow 0.35s ease,
            border-color 0.35s ease;
        background: var(--white);
    }

    .lab-card:hover {
        transform: translateY(-10px);
        box-shadow:
            0 28px 64px -12px rgba(0, 0, 0, 0.18),
            0 0 0 1.5px var(--lc);
        border-color: var(--lc);
    }

    /* Gradient header */
    .card-head {
        height: 158px;
        background: linear-gradient(
            135deg,
            var(--lc) 0%,
            color-mix(in srgb, var(--lc) 60%, #000) 100%
        );
        position: relative;
        overflow: hidden;
        transition: height 0.35s ease;
    }

    .lab-card:hover .card-head {
        height: 172px;
    }

    /* Big translucent number decoration */
    .ch-bg-num {
        position: absolute;
        right: -0.5rem;
        top: -1.75rem;
        font-size: 8rem;
        font-weight: 900;
        color: rgba(255, 255, 255, 0.1);
        line-height: 1;
        font-family: "Poppins", sans-serif;
        letter-spacing: -0.05em;
        pointer-events: none;
        user-select: none;
    }

    /* Lab icon pill */
    .ch-icon {
        position: absolute;
        bottom: 1.25rem;
        left: 1.5rem;
        width: 48px;
        height: 48px;
        font-size: 1.65rem;
        background: rgba(255, 255, 255, 0.18);
        border: 1px solid rgba(255, 255, 255, 0.28);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(8px);
        transition: transform 0.35s;
    }

    .lab-card:hover .ch-icon {
        transform: scale(1.08);
    }

    /* Card body */
    .card-body {
        padding: 1.5rem;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
    }

    .card-title {
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--text-dark);
        line-height: 1.3;
        margin: 0;
    }

    .card-desc {
        font-size: 0.875rem;
        color: var(--text-light);
        line-height: 1.65;
        flex: 1;
        margin: 0;
    }

    .card-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
        padding-top: 0.85rem;
        border-top: 1px solid var(--border-color);
        margin-top: 0.25rem;
    }

    .card-tags {
        display: flex;
        gap: 0.3rem;
        flex-wrap: wrap;
    }

    .ctag {
        font-size: 0.72rem;
        color: var(--text-light);
        background: var(--bg-light);
        padding: 0.2rem 0.55rem;
        border-radius: 100px;
        font-weight: 500;
        border: 1px solid var(--border-color);
